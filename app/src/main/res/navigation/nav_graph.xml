<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"/>
        <action
            android:id="@+id/action_registerFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.dashboard.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_generatorFragment"
            app:destination="@id/generatorFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_progressFragment"
            app:destination="@id/progressFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_historyFragment"
            app:destination="@id/historyFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_loginFragment"
            app:destination="@id/loginFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_settingsFragment"
            app:destination="@id/settingsFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_profileFragment"
            app:destination="@id/profileFragment"/>
        <action
            android:id="@+id/action_dashboardFragment_to_exercisesFragment"
            app:destination="@id/exercisesFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.profile.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profileFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/generatorFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.generator.GeneratorFragment"
        android:label="Generator">
        <action
            android:id="@+id/action_generatorFragment_to_workoutFragment"
            app:destination="@id/workoutFragment"/>
    </fragment>

    <fragment
        android:id="@+id/workoutFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.workout.WorkoutFragment"
        android:label="Workout">
        <action
            android:id="@+id/action_workoutFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/exercisesFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.exercises.ExercisesFragment"
        android:label="Exercises">
        <action
            android:id="@+id/action_exercisesFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/progressFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.progress.ProgressFragment"
        android:label="Progress">
        <action
            android:id="@+id/action_progressFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.history.HistoryFragment"
        android:label="History">
        <action
            android:id="@+id/action_historyFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"/>
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.marijamihajlovska.gymtraininggenerator.ui.settings.SettingsFragment"
        android:label="Settings">
        <action
            android:id="@+id/action_settingsFragment_to_loginFragment"
            app:destination="@id/loginFragment"/>
    </fragment>

</navigation>