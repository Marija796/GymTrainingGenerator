<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/bg_login_header">

    <!-- Left panel: branding (38%) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="38"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <ImageView
            android:id="@+id/btnLoginSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings_24"
            android:tint="#FFFFFF"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:layout_gravity="end"
            android:layout_marginBottom="16dp"/>

        <FrameLayout
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_icon_circle"
            android:layout_marginBottom="14dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_fitness_center_24"
                android:tint="#FFFFFF"
                android:scaleType="fitCenter"
                android:contentDescription="@null"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/carter_one"
            android:letterSpacing="0.03"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textColor="#FFFFFFB3"
            android:textSize="12sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Right panel: form (62%), white card with rounded left corners -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="62"
        android:background="@drawable/bg_card_rounded_left"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_back"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_in_subtitle"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"/>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/email"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/colorLoginAccent"
                app:hintTextColor="@color/colorLoginAccent"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/password"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/colorLoginAccent"
                app:hintTextColor="@color/colorLoginAccent"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/colorLoginAccent"
                android:layout_marginBottom="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/forgot_password"
                android:textColor="@color/colorLoginAccent"
                android:textSize="12sp"
                android:gravity="end|center_vertical"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/forgot_password"/>

            <!-- Login button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/login"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_login_gradient"
                android:stateListAnimator="@null"
                android:contentDescription="@string/login"
                android:layout_marginBottom="16dp"/>

            <!-- OR divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_color"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/or_divider"
                    android:textColor="@color/hint_color"
                    android:textSize="12sp"
                    android:paddingHorizontal="14dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_color"/>
            </LinearLayout>

            <!-- Google + Facebook -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginBottom="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnGoogleLogin"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp"
                    app:strokeColor="#DADCE0"
                    app:strokeWidth="1.5dp">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_google_logo"
                        android:contentDescription="@string/login_with_google"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFacebookLogin"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#1877F2"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_facebook_logo"
                        android:contentDescription="@string/login_with_facebook"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Continue as Guest -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnonymousLogin"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/continue_as_guest"
                android:textColor="@color/colorLoginAccent"
                android:textSize="13sp"
                app:strokeColor="@color/colorLoginAccent"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="@string/continue_as_guest"/>

            <!-- Register link -->
            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/no_account"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/no_account"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
